{
  "apps": {
    "adminer": {
      "name": "Adminer",
      "vetted": true,
      "type": "web",
      "description": "Web-based database management for PostgreSQL, MySQL, SQLite, and more — single PHP file, fast and lightweight",
      "category": "database",
      "author": "Jakub Vrána",
      "homepage": "https://www.adminer.org",
      "icon": "⛁",
      "keywords": ["database", "sql", "admin", "postgres", "mysql", "sqlite", "management"],
      "license": "Apache-2.0",
      "versions": {
        "4": {
          "install": "apk add --no-cache php83 php83-pdo php83-pdo_sqlite php83-pdo_pgsql php83-pdo_mysql php83-session && mkdir -p static && wget -q -O static/index.php https://github.com/vrana/adminer/releases/download/v4.8.1/adminer-4.8.1.php",
          "command": "php83 -S 0.0.0.0:${PORT} -t static/",
          "port": 8080,
          "permissions": ["network"],
          "singleton": true
        }
      }
    },
    "sqlite-web": {
      "name": "SQLite Browser",
      "vetted": true,
      "type": "web",
      "description": "Web-based SQLite database browser and query editor with syntax highlighting",
      "category": "database",
      "author": "Charles Leifer",
      "homepage": "https://github.com/coleifer/sqlite-web",
      "icon": "▦",
      "keywords": ["sqlite", "database", "browser", "editor", "sql", "query"],
      "license": "MIT",
      "versions": {
        "0.6": {
          "install": "pip3 install --break-system-packages sqlite-web",
          "command": "sqlite_web --port ${PORT} --host 0.0.0.0 --no-browser data/default.db",
          "port": 8080,
          "deps": ["python3", "py3-pip"],
          "permissions": ["network", "filesystem"],
          "singleton": true
        }
      }
    },
    "redis-commander": {
      "name": "Redis Commander",
      "vetted": true,
      "type": "web",
      "description": "Web-based Redis management tool — browse keys, run commands, monitor in real-time",
      "category": "database",
      "author": "Joe Fleming",
      "homepage": "https://github.com/joeferner/redis-commander",
      "icon": "◆",
      "keywords": ["redis", "cache", "key-value", "management", "browser", "web"],
      "license": "MIT",
      "versions": {
        "0.8": {
          "install": "apk add --no-cache nodejs npm && npm install -g redis-commander",
          "command": "redis-commander --port ${PORT} --address 0.0.0.0",
          "port": 8081,
          "deps": ["redis"],
          "permissions": ["network"],
          "singleton": true
        }
      }
    },
    "minio": {
      "name": "MinIO",
      "vetted": true,
      "type": "web",
      "description": "S3-compatible object storage with web console — store blobs, backups, and static assets",
      "category": "database",
      "author": "MinIO Inc",
      "homepage": "https://min.io",
      "icon": "⬡",
      "keywords": ["s3", "storage", "object", "blob", "backup", "minio", "web"],
      "license": "AGPL-3.0",
      "versions": {
        "latest": {
          "install": "apk add --no-cache minio minio-client",
          "command": "minio server data/minio --address :${PORT} --console-address :${CONSOLE_PORT}",
          "port": 9000,
          "env": {
            "MINIO_ROOT_USER": "minioadmin",
            "MINIO_ROOT_PASSWORD": "minioadmin",
            "CONSOLE_PORT": "9001"
          },
          "post_install": "mkdir -p data/minio",
          "permissions": ["network", "filesystem"],
          "singleton": true
        }
      }
    },
    "code-server": {
      "name": "Code Server",
      "vetted": true,
      "type": "web",
      "description": "VS Code running in the browser — full IDE with extensions, Git integration, and terminal",
      "category": "developer",
      "author": "Coder",
      "homepage": "https://coder.com",
      "icon": "⌨",
      "keywords": ["code", "editor", "vscode", "ide", "development", "programming"],
      "license": "MIT",
      "versions": {
        "4": {
          "install": "apk add --no-cache code-server",
          "command": "code-server --bind-addr 0.0.0.0:${PORT} --auth none --user-data-dir data/",
          "port": 8443,
          "permissions": ["network", "filesystem"],
          "singleton": true
        }
      }
    },
    "gitea": {
      "name": "Gitea",
      "vetted": true,
      "type": "web",
      "description": "Lightweight self-hosted Git forge with issues, pull requests, CI/CD, and package registry",
      "category": "developer",
      "author": "Gitea",
      "homepage": "https://gitea.io",
      "icon": "⑂",
      "keywords": ["git", "repository", "code", "version-control", "forge", "ci"],
      "license": "MIT",
      "versions": {
        "1": {
          "install": "apk add --no-cache gitea",
          "command": "gitea web --config data/app.ini",
          "port": 3000,
          "post_install": "mkdir -p data/repositories data/lfs && printf '[server]\\nHTTP_PORT = %s\\nROOT_URL = http://localhost:%s/\\n[repository]\\nROOT = %s/data/repositories\\n' \"${PORT}\" \"${PORT}\" \"$APP_DIR\" > data/app.ini",
          "permissions": ["network", "filesystem"],
          "singleton": true
        }
      }
    },
    "grafana": {
      "name": "Grafana",
      "vetted": true,
      "type": "web",
      "description": "Monitoring dashboards — visualize metrics from Prometheus, InfluxDB, PostgreSQL, and more",
      "category": "developer",
      "author": "Grafana Labs",
      "homepage": "https://grafana.com",
      "icon": "◉",
      "keywords": ["monitoring", "dashboard", "metrics", "grafana", "visualization", "observability"],
      "license": "AGPL-3.0",
      "versions": {
        "11": {
          "install": "apk add --no-cache grafana",
          "command": "grafana server --homepath /usr/share/grafana --config data/grafana.ini",
          "port": 3000,
          "post_install": "mkdir -p data/plugins data/dashboards && printf '[paths]\\ndata = %s/data\\nplugins = %s/data/plugins\\n[server]\\nhttp_port = %s\\n' \"$APP_DIR\" \"$APP_DIR\" \"${PORT}\" > data/grafana.ini",
          "permissions": ["network"],
          "singleton": true
        }
      }
    },
    "prometheus": {
      "name": "Prometheus",
      "vetted": true,
      "type": "web",
      "description": "Time-series monitoring and alerting with built-in web UI, PromQL query language, and scrape targets",
      "category": "developer",
      "author": "Cloud Native Computing Foundation",
      "homepage": "https://prometheus.io",
      "icon": "⊕",
      "keywords": ["monitoring", "metrics", "prometheus", "alerting", "time-series"],
      "license": "Apache-2.0",
      "versions": {
        "2": {
          "install": "apk add --no-cache prometheus",
          "command": "prometheus --config.file=data/prometheus.yml --storage.tsdb.path=data/tsdb --web.listen-address=0.0.0.0:${PORT}",
          "port": 9090,
          "post_install": "mkdir -p data/tsdb && printf 'global:\\n  scrape_interval: 15s\\nscrape_configs:\\n  - job_name: vulos\\n    static_configs:\\n      - targets: [\"localhost:8080\"]\\n' > data/prometheus.yml",
          "permissions": ["network"],
          "singleton": true
        }
      }
    },
    "ttyd": {
      "name": "ttyd",
      "vetted": true,
      "type": "web",
      "description": "Share your terminal over the web — full terminal emulation via WebSocket in the browser",
      "category": "developer",
      "author": "Shuanglei Tao",
      "homepage": "https://tsl0922.github.io/ttyd",
      "icon": ">_",
      "keywords": ["terminal", "web", "shell", "remote", "console"],
      "license": "MIT",
      "versions": {
        "1": {
          "install": "apk add --no-cache ttyd",
          "command": "ttyd --port ${PORT} --writable /bin/sh",
