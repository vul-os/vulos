    "nginx": {
      "name": "Nginx",
      "vetted": true,
      "type": "web",
      "description": "High-performance HTTP server and reverse proxy — serve static sites, proxy other services",
      "category": "network",
      "author": "F5 / Igor Sysoev",
      "homepage": "https://nginx.org",
      "icon": "▣",
      "keywords": ["web", "server", "proxy", "reverse-proxy", "http", "nginx"],
      "license": "BSD-2-Clause",
      "versions": {
        "1": {
          "install": "apk add --no-cache nginx",
          "command": "nginx -c data/nginx.conf -g 'daemon off;'",
          "port": 8080,
          "post_install": "printf 'worker_processes 1;\\nevents { worker_connections 128; }\\nhttp {\\n  include /etc/nginx/mime.types;\\n  server {\\n    listen %s;\\n    root %s/static;\\n    index index.html;\\n  }\\n}\\n' \"${PORT}\" \"$APP_DIR\" > data/nginx.conf && mkdir -p static && echo '<h1>Nginx is running</h1>' > static/index.html",
          "permissions": ["network"],
          "singleton": true
        }
      }
    },
    "caddy": {
      "name": "Caddy",
      "vetted": true,
      "type": "web",
      "description": "Modern web server with automatic HTTPS, HTTP/3, and dead-simple config",
      "category": "network",
      "author": "Matthew Holt",
      "homepage": "https://caddyserver.com",
      "icon": "▥",
      "keywords": ["web", "server", "proxy", "https", "caddy", "http3"],
      "license": "Apache-2.0",
      "versions": {
        "2": {
          "install": "apk add --no-cache caddy",
          "command": "caddy run --config data/Caddyfile --adapter caddyfile",
          "port": 8080,
          "post_install": "printf ':%s\\nroot * %s/static\\nfile_server\\n' \"${PORT}\" \"$APP_DIR\" > data/Caddyfile && mkdir -p static && echo '<h1>Caddy is running</h1>' > static/index.html",
          "permissions": ["network"],
          "singleton": true
        }
      }
    },
